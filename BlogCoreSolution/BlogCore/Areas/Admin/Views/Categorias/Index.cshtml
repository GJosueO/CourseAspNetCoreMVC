@{
    ViewData["Title"] = "Lista de categorias";
}
<div class="container mt-4 ">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary">Lista de categorias</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-pus"></i> Crear nueva categoria
            </a>
        </div>
    </div>
    <br />
    <table id="tblCategorias" class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Orden</th>
                <th>Fecha creacion</th>
                <th>Acciones</th>
            </tr>
        </thead>
    </table>
</div>
@section Scripts{
    <script src="~/js/categorias.js"></script>
}