@model IEnumerable<CrudContactosMVC.Models.Contacto> // Este fragmento permite que la vista sepa que el modelo que se le está pasando en una coleccion de objetos en este caso Lista"Contactos"
@{
    ViewData["Title"] = "Lista de contactos"; //Establece el título de la página que se muestra dentro del navegador.
}

<h1 class="text-center">Contactos:</h1> 
<p>
    <a asp-action="Crear" class="btn btn-primary">Nuevo Contacto</a> <!-- asp-action son taghelpers que ayudan a controlar la informacion que proviene de controlador -->
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Direccion</th>
            <th>Teléfono</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contacto in Model) //Este fragmento recorre cada contacto en la lista de contactos y muestra sus detalles en una fila de la tabla.
        {
            <tr>
                <td>@contacto.Id</td>
                <td>@contacto.Nombre</td>
                <td>@contacto.Correo</td>
                <td>@contacto.Direccion</td>
                <td>@contacto.Telefono</td>
                <td>
                    <a asp-action="Editar" asp-route-id="@contacto.Id" class="btn btn-sm btn-warning">Editar</a> <!-- Enlace para editar el contacto --> 
                    <a asp-action="Detalles" asp-route-id="@contacto.Id" class="btn btn-sm btn-info">Detalles</a> <!-- Enlace para ver los detalles del contacto -->
                    <a asp-action="Borrar" asp-route-id="@contacto.Id" class="btn btn-sm btn-danger">Eliminar</a> <!-- Enlace para eliminar el contacto -->
                </td>
            </tr>
        }
    </tbody>
    </table>
    @if(Model.Count() == 0){               
        <span class="text-dark fw-medium col-12">No ha registros actualmente, registra un usuario.</span>
    }
