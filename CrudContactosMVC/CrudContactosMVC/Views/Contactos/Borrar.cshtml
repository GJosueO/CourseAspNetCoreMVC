@model CrudContactosMVC.Models.Contacto;
@{
    ViewData["Title"] = "Borrar contacto";
}
<h1 class="text-center fw-semibold text-dark">Borrar Contacto</h1>
<h3 class="text-center fw-semibold text-dark">¿Estas seguro que deseas eliminar este registro?</h3>
<hr class="border" />
<dl class="row">
    <dt class="col-sm-3">ID</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>

    <dt class="col-sm-3">Correo</dt>
    <dd class="col-sm-9">@Model.Correo</dd>

    <dt class="col-sm-3">Teléfono</dt>
    <dd class="col-sm-9">@Model.Telefono</dd>

    <dt class="col-sm-3">Direccion</dt>
    <dd class="col-sm-9">@Model.Direccion</dd>
    <div class="mt-3">
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-sm btn-warning">Editar</a> <!-- Enlace para editar el contacto -->
        <form asp-action="Borrar" method="POST">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button> <!-- Botón para eliminar el contacto -->
            <a asp-action="Index" class="btn btn-sm btn-secondary">Volver</a> <!-- Enlace para editar el contacto -->
        </form>
    </div>
</dl>