{
  "ConnectionStrings": {
    //SIEMPRE LLEVA EL MISMO PATRON 'LLAVE' : 'VALOR'
    // PARAMETRO 1  - SERVIDOR - ETAMOS COMUNICANDO A MSS VERSION LIGERA DE SQL SERVER, metodologia code first. Se va a configurar nuestra base de datos a traves del codigo de nuestra conexion DBContext.
    // PARAMETRO 2 Trusted_Connection - Autenticacion de windows
    // PARAMETRO 3 HABILITA CONEXION PARA CONSULTAS QUE SE SIGUE EJECUTANDOSE

    //Esto es una buena pratica para entityframework, ya que nos permite cambiar la cadena de conexion sin necesidad de recompilar nuestro proyecto, solo cambiando el valor de esta llave.
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=CrudContactosMVC;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
